generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────
// SQLite não suporta enums nativamente. Todos os campos de
// "tipo enum" usam String e são validados na camada de app.
// Ao migrar para Postgres, substitua String por enum nativo.
// ──────────────────────────────────────────────────────────

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String
  role                    String                   @default("USER")      // USER | ADMIN
  plan                    String                   @default("FREE")      // FREE | PRO | DESK
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  alerts                  Alert[]
  watchlists              Watchlist[]
  backtests               Backtest[]
  subscriptions           Subscription[]
  notificationPreference  NotificationPreference?
  alertDeliveries         AlertDelivery[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
}

model Alert {
  id          String          @id @default(cuid())
  userId      String
  symbol      String
  timeframe   String
  condition   String
  channel     String          @default("IN_APP")     // IN_APP | EMAIL | TELEGRAM
  severity    String          @default("STANDARD")   // STANDARD | HIGH | CRITICAL
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries  AlertDelivery[]
}

model Watchlist {
  id          String      @id @default(cuid())
  userId      String
  symbol      String
  note        String?
  createdAt   DateTime    @default(now())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Backtest {
  id            String      @id @default(cuid())
  userId        String
  symbol        String
  timeframe     String
  totalTrades   Int
  winRate       Float
  netReturn     Float
  maxDrawdown   Float
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?  @unique
  stripeCheckoutId     String?  @unique
  status               String
  priceId              String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id                String    @id @default(cuid())
  userId            String    @unique
  emailEnabled      Boolean   @default(false)
  emailAddress      String?
  telegramEnabled   Boolean   @default(false)
  telegramChatId    String?
  digestEnabled     Boolean   @default(false)
  quietHoursStart   String?
  quietHoursEnd     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AlertDelivery {
  id          String           @id @default(cuid())
  userId      String
  alertId     String?
  channel     String           // IN_APP | EMAIL | TELEGRAM
  status      String           @default("PENDING")  // PENDING | SENT | FAILED
  destination String?
  subject     String?
  body        String
  error       String?
  createdAt   DateTime         @default(now())
  sentAt      DateTime?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert       Alert?           @relation(fields: [alertId], references: [id], onDelete: SetNull)
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
